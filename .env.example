# Mira Kontext API Configuration
KONTEXT_API_URL=http://localhost:8080
KONTEXT_TOKEN=replace-with-your-token

# Bot Identity
BOT_PRINCIPAL_ID=testing-bot
BOT_DISPLAY_NAME="Mira Kontext Testing Bot"
BOT_ROLES=["tester", "admin"]

# Default Project/Session
DEFAULT_PROJECT_ID=default-test-project
DEFAULT_PROJECT_TITLE="Default Test Project"
DEFAULT_SESSION_ID=default-test-session
DEFAULT_SESSION_TITLE="Default Test Session"

# Test Settings
REQUEST_TIMEOUT=30.0
DEBUG=false

# LLM Configuration (for AI-generated responses)
# Option 1: Ollama Cloud (https://docs.ollama.com/cloud — use tags from listing)
LLM_API_KEY=ollama_xxxxxxxxxxxxxxxx
LLM_BASE_URL=https://ollama.com
# Run: curl -s https://ollama.com/api/tags | python3 -c "import sys,json; print([m['name'] for m in json.load(sys.stdin).get('models',[]) if 'qwen' in m['name'].lower()])"
LLM_MODEL=qwen3-next:80b
LLM_PROVIDER=ollama

# Option 2: OpenAI
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_PROVIDER=openai

# Option 3: OpenRouter (access to many models including Qwen)
# LLM_API_KEY=sk-or-v1-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=qwen/qwen-2.5-72b-instruct
# LLM_PROVIDER=openrouter

LLM_TIMEOUT=30.0
