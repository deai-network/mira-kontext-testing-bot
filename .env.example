# Mira Kontext API Configuration
KONTEXT_API_URL=http://localhost:8080
KONTEXT_TOKEN=replace-with-your-token

# Bot Identity
BOT_PRINCIPAL_ID=testing-bot
BOT_DISPLAY_NAME="Mira Kontext Testing Bot"
BOT_ROLES=["tester", "admin"]

# Default Project/Session
DEFAULT_PROJECT_ID=default-test-project
DEFAULT_PROJECT_TITLE="Default Test Project"
DEFAULT_SESSION_ID=default-test-session
DEFAULT_SESSION_TITLE="Default Test Session"

# Test Settings
REQUEST_TIMEOUT=30.0
DEBUG=false

# LLM Configuration (for AI-generated responses)
# Nebius OpenAI-compatible endpoint
NEBIUS_API_KEY=replace-with-nebius-key
LLM_BASE_URL=https://api.tokenfactory.nebius.com/v1/
LLM_MODEL=openai/gpt-oss-120b
LLM_PROVIDER=nebius

# Optional: override with a separate key for the response model
# LLM_API_KEY=replace-with-llm-key

LLM_TIMEOUT=30.0

# Fast Intent Classifier (separate, low-latency model for action routing)
# Uses Nebius OpenAI-compatible endpoint by default.
# If INTENT_API_KEY is omitted, NEBIUS_API_KEY is used.
# You can set a smaller Qwen/Nemotron-compatible chat model here for faster routing.
INTENT_API_KEY=
INTENT_BASE_URL=https://api.tokenfactory.nebius.com/v1/
INTENT_MODEL=openai/gpt-oss-120b
INTENT_PROVIDER=nebius
INTENT_CONFIDENCE_THRESHOLD=0.75
INTENT_TIMEOUT=8.0

# Web Fetching Configuration
# Firecrawl API key for scraping web pages (https://firecrawl.dev)
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxx
# Whether to propose web search when local sources return no results
AUTO_WEB_SEARCH=true
